{
  "$schema": "https://rahmanef63.github.io/resource-site/rr.schema.json",
  "version": 1,
  "framework": "next-16",
  "style": "shadcn-new-york",
  "rsc": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "app/globals.css"
  },
  "aliases": {
    "components": "@/components",
    "ui": "@/components/ui",
    "shared": "@/features/_shared",
    "templates": "@/features",
    "slices": "@/features",
    "features": "@/features",
    "convex": "@/convex",
    "lib": "@/lib",
    "hooks": "@/hooks"
  },
  "layout": {
    "kind": "vertical-slice",
    "publicRoute": "app/(public)",
    "adminRoute": "app/(admin)",
    "sliceRoot": "frontend/slices"
  },
  "template": {
    "slug": "personal-brand-os",
    "version": "main"
  },
  "features": [],
  "slices": [],
  "skills": [],
  "auth": {
    "provider": "convex-auth"
  },
  "convex": {
    "self_hosted": false,
    "cloud": true
  }
}
